# Dev-environment defaults. Copy to terraform.tfvars (gitignored) and adjust.

region       = "us-east-1"
environment  = "dev"
cluster_name = "eks-control-plane-dev"

cluster_version = "1.35"
vpc_cidr        = "10.0.0.0/16"

node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4

# Fill in with the bucket name scripts/bootstrap.sh prints. Must match what
# is in envs/dev/backend.hcl. State locking uses S3 native conditional
# writes (use_lockfile in backend.hcl), so no DynamoDB table is needed.
state_bucket_name = "eks-control-plane-tfstate-REPLACE_ME"

backend_namespace       = "control-plane"
backend_service_account = "backend"

tags = {
  Owner = "platform"
}

# Custom HTTPS domain (optional). Leave domain_name empty to skip cert + DNS
# resources entirely. When set, the first `terraform apply` creates and
# DNS-validates an ACM cert; a second apply with create_dns_alias=true
# (after `make deploy` provisions the ALB) writes the Route53 A-alias.
domain_name      = ""
subdomain        = ""
hosted_zone_id   = ""
create_dns_alias = false
